# CI restores NuGet packages into the workspace (.nuget/packages via NUGET_PACKAGES in ci.yml);
# third-party package content must never gate formatting.
.nuget/
.vscode/
.worktrees/
.context/
artifacts/

# Verify source-generator snapshots preserve the generator's exact output. Formatting these files
# changes the contract under test and causes the corresponding received/verified comparison to fail.
**/Snapshots/**/*.verified.cs

# CSharpier 1.3.0's XML check produces a different result for this hand-maintained file on
# Linux (CI) than on macOS (local) — macOS treats it as already-formatted while Linux flags it
# "Was not formatted". Confirmed by CI run 27877390395. It is not authored code, so it is
# excluded from the gate rather than letting a platform-dependent formatter break the build.
nuget.config
