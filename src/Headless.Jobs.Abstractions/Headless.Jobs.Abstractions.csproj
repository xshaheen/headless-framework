<Project Sdk="Headless.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <RootNamespace>Headless.Jobs</RootNamespace>
  </PropertyGroup>
  <ItemGroup>
    <InternalsVisibleTo Include="Headless.Jobs.Tests.Unit" />
    <InternalsVisibleTo Include="Headless.Jobs.Core" />
    <InternalsVisibleTo Include="Headless.Jobs.Dashboard" />
    <InternalsVisibleTo Include="Headless.Jobs.EntityFramework" />
    <InternalsVisibleTo Include="Headless.Jobs.OpenTelemetry" />
    <!-- Lets NSubstitute proxy internal types. -->
    <InternalsVisibleTo Include="DynamicProxyGenAssembly2" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="NCrontab.Signed" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\Headless.Hosting\Headless.Hosting.csproj" />
    <!-- Deliberate always-on dependency: the UseDistributedLock overloads live on JobsOptionsBuilder, so every
         Jobs.Abstractions consumer transitively references this even when not using the lock. Kept structural (not
         optional) because the dep is backend-free (only Headless.Checks + Headless.Extensions, no lock providers), so
         the zero-lock-in cost is negligible. -->
    <ProjectReference Include="..\Headless.DistributedLocks.Abstractions\Headless.DistributedLocks.Abstractions.csproj" />
  </ItemGroup>
</Project>
