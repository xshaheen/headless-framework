<Project Sdk="Headless.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Description>Core services, options, and setup primitives for Headless API packages.</Description>
    <PackageTags>headless;api;dotnet</PackageTags>
    <RootNamespace>Headless.Api</RootNamespace>
  </PropertyGroup>
  <ItemGroup>
    <InternalsVisibleTo Include="Headless.Api.ServiceDefaults" />
    <InternalsVisibleTo Include="Headless.Api.Tests.Unit" />
    <InternalsVisibleTo Include="Headless.Api.Tests.Integration" />
    <InternalsVisibleTo Include="Headless.Api.Mvc.Tests.Unit" />
    <InternalsVisibleTo Include="Headless.Api.Idempotency.Tests.Integration" />
  </ItemGroup>
  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
    <PackageReference Include="Asp.Versioning.Abstractions" />
    <PackageReference Include="Asp.Versioning.Http" />
    <PackageReference Include="DeviceDetector.NET" />
    <PackageReference Include="FluentValidation.DependencyInjectionExtensions" />
    <PackageReference Include="Microsoft.AspNetCore.MiddlewareAnalysis" />
    <PackageReference Include="Microsoft.Extensions.DiagnosticAdapter" />
    <PackageReference Include="Microsoft.Extensions.Http.Resilience" />
    <PackageReference Include="Microsoft.IdentityModel.JsonWebTokens" />
    <PackageReference Include="NetEscapades.AspNetCore.SecurityHeaders" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\Headless.Api.Abstractions\Headless.Api.Abstractions.csproj" />
    <ProjectReference Include="..\Headless.Core\Headless.Core.csproj" />
    <ProjectReference Include="..\Headless.MultiTenancy\Headless.MultiTenancy.csproj" />
    <ProjectReference Include="..\Headless.Security\Headless.Security.csproj" />
    <ProjectReference Include="..\Headless.Caching.Abstractions\Headless.Caching.Abstractions.csproj" />
    <ProjectReference Include="..\Headless.FluentValidation\Headless.FluentValidation.csproj" />
    <ProjectReference Include="..\Headless.Api.FluentValidation\Headless.Api.FluentValidation.csproj" />
    <ProjectReference Include="..\Headless.Hosting\Headless.Hosting.csproj" />
  </ItemGroup>
  <ItemGroup Label="Resources">
    <EmbeddedResource Update="Resources\Messages.resx" />
  </ItemGroup>
</Project>
