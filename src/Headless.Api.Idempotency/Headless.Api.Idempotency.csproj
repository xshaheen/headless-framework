    <ProjectReference Include="..\Headless.Checks\Headless.Checks.csproj" />
    <ProjectReference Include="..\Headless.Caching.Abstractions\Headless.Caching.Abstractions.csproj" />
    <ProjectReference Include="..\Headless.Core\Headless.Core.csproj" />
    <ProjectReference Include="..\Headless.DistributedLocks.Abstractions\Headless.DistributedLocks.Abstractions.csproj" />
    <ProjectReference Include="..\Headless.FluentValidation\Headless.FluentValidation.csproj" />
    <ProjectReference Include="..\Headless.Hosting\Headless.Hosting.csproj" />
  </ItemGroup>
  <ItemGroup Label="Resources">
    <EmbeddedResource Update="Resources\Messages.resx" />
  </ItemGroup>
</Project>
