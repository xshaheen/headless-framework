<Project Sdk="Headless.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Description>PostgreSQL storage provider for Headless settings.</Description>
    <PackageTags>headless;settings;storage;postgresql;dotnet</PackageTags>
    <RootNamespace>Headless.Settings.PostgreSql</RootNamespace>
    <NoWarn>$(NoWarn);CA2100</NoWarn>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Npgsql" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\Headless.Serializer.Json\Headless.Serializer.Json.csproj" />
    <ProjectReference Include="..\Headless.Settings.Core\Headless.Settings.Core.csproj" />
  </ItemGroup>
</Project>
