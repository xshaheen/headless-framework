<Project Sdk="Headless.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Description>Audit log DI setup package with options validation, setup builders, and exactly-one-storage-provider registration.</Description>
    <PackageTags>headless;audit;log;dotnet</PackageTags>
    <RootNamespace>Headless.AuditLog</RootNamespace>
  </PropertyGroup>
  <ItemGroup>
    <InternalsVisibleTo Include="Headless.AuditLog.Storage.EntityFramework" />
    <InternalsVisibleTo Include="Headless.AuditLog.Storage.PostgreSql" />
    <InternalsVisibleTo Include="Headless.AuditLog.Storage.SqlServer" />
    <InternalsVisibleTo Include="Headless.AuditLog.Core.Tests.Unit" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="FluentValidation" />
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" />
    <PackageReference Include="Microsoft.Extensions.Options" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\Headless.AuditLog.Abstractions\Headless.AuditLog.Abstractions.csproj" />
    <ProjectReference Include="..\Headless.Checks\Headless.Checks.csproj" />
    <ProjectReference Include="..\Headless.Hosting\Headless.Hosting.csproj" />
  </ItemGroup>
</Project>
