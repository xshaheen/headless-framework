<Project Sdk="Headless.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Description>FluentValidation helpers and reusable validation extensions for Headless Framework packages.</Description>
    <PackageTags>headless;fluentvalidation;dotnet</PackageTags>
    <RootNamespace>FluentValidation</RootNamespace>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="FluentValidation" />
    <PackageReference Include="libphonenumber-csharp" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\Headless.Extensions\Headless.Extensions.csproj" />
  </ItemGroup>
  <ItemGroup Label="Resources">
    <EmbeddedResource Update="Resources\FluentValidatorErrors.resx" />
  </ItemGroup>
</Project>
