<Project Sdk="Headless.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Description>SQL Server storage provider for Headless audit logging.</Description>
    <PackageTags>headless;audit;log;storage;sql-server;dotnet</PackageTags>
    <RootNamespace>Headless.AuditLog.SqlServer</RootNamespace>
    <NoWarn>$(NoWarn);CA2100</NoWarn>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.Data.SqlClient" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\Headless.AuditLog.Abstractions\Headless.AuditLog.Abstractions.csproj" />
    <ProjectReference Include="..\Headless.AuditLog.Core\Headless.AuditLog.Core.csproj" />
    <ProjectReference Include="..\Headless.Core\Headless.Core.csproj" />
    <ProjectReference Include="..\Headless.Serializer.Json\Headless.Serializer.Json.csproj" />
  </ItemGroup>
</Project>
