<Project Sdk="Headless.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
  </PropertyGroup>
  <ItemGroup>
    <InternalsVisibleTo Include="Headless.Sms.Infobip.Tests.Unit" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="Infobip.Api.Client" />
    <!--
      Infobip.Api.Client pulls legacy Polly v7, whose namespaces collide with Polly.Core v8 (from
      Http.Resilience). Alias the v7 assembly so our code resolves Polly.Timeout/Polly.CircuitBreaker
      against Polly.Core; the SDK still binds v7 at runtime.
    -->
    <PackageReference Include="Polly" Aliases="pollyV7" />
    <PackageReference Include="Microsoft.Extensions.Http.Resilience" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\Headless.Hosting\Headless.Hosting.csproj" />
    <ProjectReference Include="..\Headless.Sms.Abstractions\Headless.Sms.Abstractions.csproj" />
  </ItemGroup>
</Project>
