<Project Sdk="Headless.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Description>Dashboard UI and endpoints for Headless background jobs.</Description>
    <PackageTags>headless;jobs;dashboard;dotnet</PackageTags>
    <RootNamespace>Headless.Jobs</RootNamespace>
  </PropertyGroup>
  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>
  <ItemGroup>
    <InternalsVisibleTo Include="Headless.Jobs.Tests.Unit" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\Headless.Coordination.Abstractions\Headless.Coordination.Abstractions.csproj" />
    <ProjectReference Include="..\Headless.Dashboard.Authentication\Headless.Dashboard.Authentication.csproj" />
    <ProjectReference Include="..\Headless.Extensions\Headless.Extensions.csproj" />
    <ProjectReference Include="..\Headless.Jobs.Abstractions\Headless.Jobs.Abstractions.csproj" />
    <ProjectReference Include="..\Headless.Jobs.Core\Headless.Jobs.Core.csproj" />
  </ItemGroup>
  <!-- Builds wwwroot SPA and embeds wwwroot/dist/** at build time (dist is gitignored, not committed). -->
  <Import Project="$(MSBuildThisFileDirectory)..\..\eng\DashboardSpa.targets" />
</Project>
