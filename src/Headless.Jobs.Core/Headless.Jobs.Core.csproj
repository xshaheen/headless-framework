<Project Sdk="Headless.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Description>Core services, options, and setup primitives for Headless background jobs packages.</Description>
    <PackageTags>headless;jobs;dotnet</PackageTags>
    <RootNamespace>Headless.Jobs</RootNamespace>
  </PropertyGroup>
  <ItemGroup>
    <InternalsVisibleTo Include="Headless.Jobs.Composition.Tests.Unit" />
    <InternalsVisibleTo Include="Headless.Jobs.Benchmarks" />
    <InternalsVisibleTo Include="Headless.Jobs.Dashboard" />
    <InternalsVisibleTo Include="Headless.Jobs.EntityFramework" />
    <!-- Lets NSubstitute proxy internal types. -->
    <InternalsVisibleTo Include="DynamicProxyGenAssembly2" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="NCrontab.Signed" />
    <PackageReference Include="OpenTelemetry.Api" />
    <PackageReference Include="Polly.Core" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\Headless.Jobs.Abstractions\Headless.Jobs.Abstractions.csproj" />
    <ProjectReference Include="..\Headless.DistributedLocks.Abstractions\Headless.DistributedLocks.Abstractions.csproj" />
    <ProjectReference Include="..\Headless.Coordination.Abstractions\Headless.Coordination.Abstractions.csproj" />
    <ProjectReference Include="..\Headless.Coordination.Core\Headless.Coordination.Core.csproj" />
    <ProjectReference Include="..\Headless.MultiTenancy\Headless.MultiTenancy.csproj" />
  </ItemGroup>
  <Target Name="CopyAnalyzer" AfterTargets="Build">
    <MakeDir Directories="$(OutputPath)analyzers/dotnet/cs" />
  </Target>
  <ItemGroup>
    <None
      Include="..\Headless.Jobs.SourceGenerator\bin\$(Configuration)\netstandard2.0\Headless.Jobs.SourceGenerator.dll"
      Pack="true"
      PackagePath="analyzers/dotnet/cs"
    />
  </ItemGroup>
</Project>
