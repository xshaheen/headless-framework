<Project Sdk="Headless.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Description>Dashboard UI and endpoints for Headless messaging.</Description>
    <PackageTags>headless;messaging;dashboard;dotnet</PackageTags>
  </PropertyGroup>
  <ItemGroup>
    <SupportedPlatform Include="browser" />
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
    <InternalsVisibleTo Include="Headless.Messaging.Dashboard.K8s" />
    <InternalsVisibleTo Include="Headless.Messaging.Dashboard.K8s.Tests.Unit" />
    <InternalsVisibleTo Include="Headless.Messaging.Dashboard.Tests.Unit" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="Consul" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\Headless.Dashboard.Authentication\Headless.Dashboard.Authentication.csproj" />
    <ProjectReference Include="..\Headless.Messaging.Core\Headless.Messaging.Core.csproj" />
  </ItemGroup>
  <!-- Builds wwwroot SPA and embeds wwwroot/dist/** at build time (dist is gitignored, not committed). -->
  <Import Project="$(MSBuildThisFileDirectory)..\..\eng\DashboardSpa.targets" />
</Project>
