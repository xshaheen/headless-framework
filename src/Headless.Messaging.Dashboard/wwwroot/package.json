{
  "name": "messaging-dashboard",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "lint": "eslint . --fix",
    "lint:check": "eslint .",
    "format": "prettier --write src/"
  },
  "dependencies": {
    "axios": "^1.18.1",
    "echarts": "^5.5.0",
    "json-bigint": "^1.0.0",
    "pinia": "^3.0.4",
    "timeago.js": "^4.0.2",
    "vite-plugin-dynamic-base": "^1.4.1",
    "vue": "^3.5.39",
    "vue-echarts": "^7.0.0",
    "vue-router": "^4.5.0",
    "vuetify": "^4.1.2"
  },
  "devDependencies": {
    "@mdi/font": "^7.4.47",
    "@tsconfig/node22": "^22.0.0",
    "@types/axios": "^0.14.4",
    "@types/json-bigint": "^1.0.4",
    "@types/node": "^26.1.0",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/eslint-config-prettier": "^10.1.0",
    "@vue/eslint-config-typescript": "^14.9.0",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.6.0",
    "eslint-plugin-vue": "^10.9.2",
    "happy-dom": "^20.10.6",
    "npm-run-all2": "^7.0.2",
    "prettier": "^3.9.4",
    "typescript": "~5.9.3",
    "vite": "^6.4.3",
    "vite-plugin-dts": "^4.5.0",
    "vite-plugin-vue-devtools": "^7.6.8",
    "vitest": "^4.1.9",
    "vue-tsc": "^3.3.6"
  },
  "overrides": {
    "fast-uri": "3.1.2",
    "shell-quote": "1.8.4",
    "form-data": "^4.0.6",
    "js-yaml": "^4.2.0",
    "@babel/core": "^7.29.6"
  }
}
