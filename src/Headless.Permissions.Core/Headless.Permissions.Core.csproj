<Project Sdk="Headless.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Description>Core services, options, and setup primitives for Headless permissions packages.</Description>
    <PackageTags>headless;permissions;dotnet</PackageTags>
    <RootNamespace>Headless.Permissions</RootNamespace>
  </PropertyGroup>
  <ItemGroup>
    <InternalsVisibleTo Include="Headless.Permissions.Composition.Tests.Unit" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.AspNetCore.Authorization" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\Headless.Extensions\Headless.Extensions.csproj" />
    <ProjectReference Include="..\Headless.Domain\Headless.Domain.csproj" />
    <ProjectReference Include="..\Headless.Caching.Abstractions\Headless.Caching.Abstractions.csproj" />
    <ProjectReference Include="..\Headless.Hosting\Headless.Hosting.csproj" />
    <ProjectReference Include="..\Headless.Permissions.Abstractions\Headless.Permissions.Abstractions.csproj" />
    <ProjectReference Include="..\Headless.DistributedLocks.Abstractions\Headless.DistributedLocks.Abstractions.csproj" />
    <ProjectReference Include="..\Headless.Messaging.Abstractions\Headless.Messaging.Abstractions.csproj" />
    <ProjectReference Include="..\Headless.Messaging.Bus.Abstractions\Headless.Messaging.Bus.Abstractions.csproj" />
  </ItemGroup>
  <ItemGroup Label="Resources">
    <EmbeddedResource Update="Resources\Messages.resx" />
  </ItemGroup>
</Project>
