<Project Sdk="Headless.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Description>OpenTelemetry instrumentation for Headless background jobs.</Description>
    <PackageTags>headless;jobs;opentelemetry;dotnet</PackageTags>
    <RootNamespace>Headless.Jobs</RootNamespace>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="OpenTelemetry" />
    <PackageReference Include="OpenTelemetry.Extensions.Hosting" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\Headless.Jobs.Abstractions\Headless.Jobs.Abstractions.csproj" />
    <ProjectReference Include="..\Headless.Jobs.Core\Headless.Jobs.Core.csproj" />
  </ItemGroup>
</Project>
