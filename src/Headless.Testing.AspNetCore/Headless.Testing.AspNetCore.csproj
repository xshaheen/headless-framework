<Project Sdk="Headless.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Description>ASP.NET Core integration for Headless testing.</Description>
    <PackageTags>headless;testing;aspnetcore;dotnet</PackageTags>
    <IsTestProject>false</IsTestProject>
  </PropertyGroup>
  <ItemGroup>
    <InternalsVisibleTo Include="Headless.Testing.AspNetCore.Tests.Unit" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.AspNetCore.Mvc.Testing" />
    <PackageReference Include="Microsoft.EntityFrameworkCore.Relational" />
    <PackageReference Include="Respawn" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\Headless.Hosting\Headless.Hosting.csproj" />
    <ProjectReference Include="..\Headless.Testing\Headless.Testing.csproj" />
    <ProjectReference Include="..\Headless.Messaging.Testing\Headless.Messaging.Testing.csproj" />
  </ItemGroup>
</Project>
