<Project Sdk="Headless.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Description>AWS integration for Headless blob storage.</Description>
    <PackageTags>headless;blobs;aws;dotnet</PackageTags>
  </PropertyGroup>
  <ItemGroup>
    <InternalsVisibleTo Include="Headless.Blobs.Aws.Tests.Unit" />
    <InternalsVisibleTo Include="Headless.Blobs.Aws.Tests.Integration" />
    <!-- CloudflareR2 reuses the internal AwsBlobStorage engine; its tests construct it directly. -->
    <InternalsVisibleTo Include="Headless.Blobs.CloudflareR2" />
    <InternalsVisibleTo Include="Headless.Blobs.CloudflareR2.Tests.Integration" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="AWSSDK.Extensions.NETCore.Setup" />
    <PackageReference Include="AWSSDK.S3" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\Headless.Blobs.Abstractions\Headless.Blobs.Abstractions.csproj" />
    <ProjectReference Include="..\Headless.Blobs.Core\Headless.Blobs.Core.csproj" />
    <ProjectReference Include="..\Headless.Core\Headless.Core.csproj" />
    <ProjectReference Include="..\Headless.Hosting\Headless.Hosting.csproj" />
  </ItemGroup>
</Project>
