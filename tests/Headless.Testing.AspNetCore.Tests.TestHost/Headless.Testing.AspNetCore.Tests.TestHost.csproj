<Project Sdk="Microsoft.NET.Sdk.Web">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <IsTestProject>false</IsTestProject>
    <IsTestableProject>false</IsTestableProject>
  </PropertyGroup>
  <ItemGroup>
    <InternalsVisibleTo Include="Headless.Testing.AspNetCore.Tests.Unit" />
  </ItemGroup>
  <!-- Remove test-only items inherited from tests/Directory.Build.props -->
  <ItemGroup>
    <Using Remove="Xunit" />
    <Using Remove="NSubstitute" />
    <Using Remove="Bogus" />
    <Using Remove="AwesomeAssertions" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Remove="Bogus" />
    <PackageReference Remove="DeepCloner" />
    <PackageReference Remove="AwesomeAssertions" />
    <PackageReference Remove="AwesomeAssertions.Json" />
    <PackageReference Remove="NSubstitute" />
    <PackageReference Remove="AwesomeAssertions.Analyzers" />
    <PackageReference Remove="NSubstitute.Analyzers.CSharp" />
  </ItemGroup>
  <ItemGroup>
    <Content Remove="../xunit.runner.json" />
  </ItemGroup>
</Project>
